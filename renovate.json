{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableRateLimiting"],
  "enabledManagers": ["npm"],
  "labels": ["renovate"],
  "dependencyDashboard": true,
  "prCreation": "immediate",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "enabled": true
  }
}
